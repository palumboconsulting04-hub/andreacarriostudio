# Token de acceso de Meta con permiso ads_read.
# Recomendado: System User token de larga duración (no caduca pronto).
# IMPORTANTE: copia este archivo a ".env" y pega ahí tu token.
# El .env real NUNCA se sube a git (ya está en .gitignore).
META_ACCESS_TOKEN=

# ID de la cuenta publicitaria, SIN el prefijo "act_".
# Por defecto: cuenta del estudio "Palumbo consulting".
META_AD_ACCOUNT_ID=1239097093670462

# Versión de la Graph API. Si una versión da error de "deprecated"/"unsupported",
# prueba a subirla (p. ej. v23.0).
META_API_VERSION=v22.0
